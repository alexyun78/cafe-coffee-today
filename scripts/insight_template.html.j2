<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title_ko }} — 92°C ROASTERY</title>
<meta name="description" content="{{ one_liner|e }}">
<link rel="icon" type="image/png" href="/static/img/logo-92black.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --canvas: #FFFFFF; --canvas-warm: #FAF7F2; --canvas-stone: #F2ECE3;
  --ink: #1A1410; --ink-mute: #4A3F36; --ink-soft: #6B5E52;
  --espresso: #6F4E37; --caramel: #C9986A; --copper: #B5703D;
  --line: #E8E0D5; --line-soft: #F0E9DD;
  --font-display: "Cormorant Garamond", "Pretendard", serif;
  --font-body: "Pretendard", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, monospace;
  --r-sm: 6px; --r-md: 12px; --r-pill: 999px;
}
* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color: transparent; }
html { scroll-behavior: smooth; }
body { font-family: var(--font-body); color: var(--ink); background: var(--canvas); font-feature-settings: "kern","ss01"; line-height: 1.65; -webkit-font-smoothing: antialiased; }
a { color: var(--copper); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color .2s; }
a:hover { border-bottom-color: var(--copper); }
img { display: block; max-width: 100%; height: auto; }
.container { max-width: 860px; margin: 0 auto; padding: 0 32px; }
@media (max-width: 720px) { .container { padding: 0 20px; } }
@media (max-width: 480px) { .container { padding: 0 16px; } }
.site-nav { position: sticky; top: 0; z-index: 50; background: rgba(255,255,255,0.9); backdrop-filter: saturate(140%) blur(14px); -webkit-backdrop-filter: saturate(140%) blur(14px); border-bottom: 1px solid var(--line-soft); }
.nav-inner { max-width: 1200px; margin: 0 auto; padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; }
.brand { font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; color: var(--ink); display: inline-flex; align-items: center; gap: 4px; border-bottom: none; }
.brand:hover { border-bottom: none; }
.brand-mark { display: inline-flex; align-items: flex-start; font-family: "Pretendard", sans-serif; font-weight: 900; letter-spacing: -0.04em; line-height: 1; color: inherit; }
.temp-mark { display: flex; flex-direction: column; line-height: .82; margin: 0 .05em 0 .04em; }
.temp-mark .temp-deg { font-size: .42em; letter-spacing: -.04em; }
.temp-mark .temp-c { font-size: .58em; letter-spacing: -.05em; margin-top: -.05em; }
.nav-back { font-family: var(--font-mono); font-size: .75rem; letter-spacing: .18em; color: var(--ink-mute); border-bottom: none; }
.nav-back:hover { color: var(--copper); border-bottom: none; }
.article-hero { padding: 56px 0 48px; border-bottom: 1px solid var(--line-soft); }
.eyebrow { font-family: var(--font-mono); font-size: .72rem; letter-spacing: .28em; color: var(--copper); margin-bottom: 18px; display: flex; align-items: center; gap: 12px; }
.eyebrow::before { content: ""; display: inline-block; width: 28px; height: 1px; background: var(--copper); }
.article-title { font-family: var(--font-display); font-weight: 500; font-size: clamp(2rem, 4.5vw, 3.2rem); line-height: 1.15; letter-spacing: -0.02em; color: var(--ink); margin-bottom: 20px; }
.article-title em { font-style: italic; color: var(--espresso); font-weight: 600; }
.article-one-liner { font-family: var(--font-display); font-style: italic; font-size: 1.3rem; line-height: 1.5; color: var(--espresso); margin-bottom: 28px; padding-left: 20px; border-left: 3px solid var(--caramel); }
.article-meta { display: flex; gap: 24px; flex-wrap: wrap; font-family: var(--font-mono); font-size: .75rem; letter-spacing: .12em; color: var(--ink-soft); padding-top: 20px; border-top: 1px solid var(--line-soft); }
.article-meta span { display: inline-flex; align-items: center; gap: 6px; }
.article-meta span::before { content: "■"; color: var(--caramel); font-size: .55rem; }
.hero-image { margin: 32px 0 0; border-radius: var(--r-md); overflow: hidden; border: 1px solid var(--line); }
.hero-image img { width: 100%; }
.article-body { padding: 56px 0 80px; }
.section-block { margin-bottom: 56px; }
.section-block:last-child { margin-bottom: 0; }
.section-block h2 { font-family: var(--font-display); font-weight: 600; font-size: 1.85rem; line-height: 1.2; letter-spacing: -0.01em; color: var(--ink); margin-bottom: 18px; display: flex; align-items: baseline; gap: 14px; }
.section-block h2::before { content: ""; display: inline-block; width: 10px; height: 10px; background: var(--caramel); border-radius: 2px; }
.section-block p { font-size: 1.04rem; color: var(--ink-mute); line-height: 1.85; margin-bottom: 18px; }
.section-block p:last-child { margin-bottom: 0; }
ul.findings { list-style: none; padding: 0; counter-reset: f; }
ul.findings li { position: relative; padding: 16px 18px 16px 56px; font-size: 1rem; color: var(--ink-mute); line-height: 1.75; background: var(--canvas-warm); border: 1px solid var(--line); border-radius: var(--r-sm); margin-bottom: 12px; counter-increment: f; }
ul.findings li::before { content: counter(f, decimal-leading-zero); position: absolute; left: 18px; top: 18px; font-family: var(--font-mono); font-size: .85rem; font-weight: 600; color: var(--copper); letter-spacing: .04em; }
.implications-grid { display: grid; gap: 18px; grid-template-columns: 1fr; }
.implication-card { padding: 22px 24px; background: var(--canvas-warm); border: 1px solid var(--line); border-radius: var(--r-md); border-left: 3px solid var(--caramel); }
.implication-card h3 { font-family: var(--font-mono); font-size: .8rem; letter-spacing: .18em; color: var(--copper); margin-bottom: 10px; font-weight: 600; }
.implication-card p { font-size: 1rem; color: var(--ink-mute); line-height: 1.75; }
.glossary-list { list-style: none; padding: 0; }
.glossary-list li { padding: 16px 0; border-bottom: 1px solid var(--line-soft); display: grid; grid-template-columns: 220px 1fr; gap: 24px; font-size: 1rem; line-height: 1.7; }
.glossary-list li:last-child { border-bottom: none; }
.glossary-list dt { font-family: var(--font-display); font-style: italic; font-size: 1.05rem; color: var(--espresso); font-weight: 600; }
.glossary-list dd { color: var(--ink-mute); }
@media (max-width: 600px) { .glossary-list li { grid-template-columns: 1fr; gap: 4px; } }
.citation-block { margin-top: 12px; padding: 22px 24px; background: var(--canvas-warm); border: 1px solid var(--line); border-radius: var(--r-md); font-family: var(--font-mono); font-size: .85rem; color: var(--ink-mute); line-height: 1.7; word-break: break-word; }
.links-row { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 18px; }
.link-pill { display: inline-flex; align-items: center; gap: 8px; padding: 9px 16px; background: var(--canvas-warm); border: 1px solid var(--line); border-radius: var(--r-pill); font-family: var(--font-mono); font-size: .78rem; letter-spacing: .08em; color: var(--ink-mute); border-bottom: 1px solid var(--line); transition: border-color .2s, color .2s; }
.link-pill:hover { color: var(--copper); border-color: var(--copper); }
.charts-grid { display: grid; gap: 28px; grid-template-columns: 1fr; }
@media (min-width: 720px) { .charts-grid { grid-template-columns: 1fr 1fr; } }
.chart-card { padding: 24px 24px 18px; background: var(--canvas); border: 1px solid var(--line); border-radius: var(--r-md); }
.chart-title { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; color: var(--ink); margin-bottom: 14px; line-height: 1.3; }
.chart-svg { width: 100%; height: auto; display: block; }
.chart-svg .bar { fill: var(--caramel); transition: fill .2s; }
.chart-svg .bar.highlight { fill: var(--copper); }
.chart-svg .axis-line { stroke: var(--line); stroke-width: 1; }
.chart-svg .axis-label { font-family: var(--font-mono); font-size: 11px; fill: var(--ink-soft); }
.chart-svg .value-label { font-family: var(--font-mono); font-size: 11px; font-weight: 600; fill: var(--espresso); }
.chart-svg .y-label { font-family: var(--font-mono); font-size: 10px; fill: var(--ink-soft); letter-spacing: .1em; }
.figures-grid { display: flex; flex-direction: column; gap: 24px; }
.figure-card { border: 1px solid var(--line); border-radius: var(--r-md); overflow: hidden; }
.figure-card img { width: 100%; }
.figure-caption { padding: 14px 18px; font-size: .9rem; color: var(--ink-soft); font-family: var(--font-body); line-height: 1.6; background: var(--canvas-warm); border-top: 1px solid var(--line); }
.source-basis { display: inline-flex; align-items: center; gap: 8px; padding: 6px 14px; background: rgba(201,152,106,.18); border: 1px solid rgba(181,112,61,.35); border-radius: var(--r-pill); font-family: var(--font-mono); font-size: .72rem; letter-spacing: .12em; color: var(--espresso); font-weight: 500; }
.source-basis.abstract { background: rgba(107,94,82,.1); border-color: rgba(107,94,82,.3); color: var(--ink-soft); }
.article-footer { padding: 36px 0 56px; border-top: 1px solid var(--line-soft); text-align: center; font-family: var(--font-mono); font-size: .75rem; letter-spacing: .14em; color: var(--ink-soft); }
.article-footer a { color: var(--ink-mute); border-bottom: 1px solid transparent; }
.article-footer a:hover { color: var(--copper); border-bottom-color: var(--copper); }
@media (max-width: 720px) {
  .article-hero { padding: 36px 0 32px; }
  .article-body { padding: 36px 0 56px; }
  .section-block { margin-bottom: 40px; }
  .section-block h2 { font-size: 1.5rem; }
  .article-meta { gap: 12px 18px; font-size: .68rem; }
}
</style>
</head>
<body>

<header class="site-nav">
  <div class="nav-inner">
    <a class="brand" href="/">
      <span class="brand-mark">92<span class="temp-mark"><span class="temp-deg">°</span><span class="temp-c">C</span></span></span>ROASTERY
    </a>
    <a class="nav-back" href="/insight">← INSIGHTS</a>
  </div>
</header>

<article>
  <section class="article-hero">
    <div class="container">
      <div class="eyebrow">— COFFEE INSIGHT · {{ date_display }}</div>
      <h1 class="article-title">{{ title_ko|e }}</h1>
      {% if one_liner %}<p class="article-one-liner">{{ one_liner|e }}</p>{% endif %}
      <div class="article-meta">
        {% if journal %}<span>{{ journal|upper|e }}</span>{% endif %}
        {% if pub_date %}<span>{{ pub_date }}</span>{% endif %}
        {% if doi %}<span>DOI {{ doi|upper|e }}</span>{% endif %}
        {% if all_categories %}<span>{{ all_categories|e }}</span>{% endif %}
      </div>
      {% if hero_image %}
      <div class="hero-image">
        <img src="{{ hero_image }}" alt="{{ title_ko|e }}">
      </div>
      {% endif %}
    </div>
  </section>

  <section class="article-body">
    <div class="container">

      {% if summary_paragraphs %}
      <div class="section-block">
        <h2>요약</h2>
        {% for p in summary_paragraphs %}<p>{{ p|e }}</p>{% endfor %}
      </div>
      {% endif %}

      {% if key_findings %}
      <div class="section-block">
        <h2>핵심 발견</h2>
        <ul class="findings">
          {% for f in key_findings %}<li>{{ f|e }}</li>{% endfor %}
        </ul>
      </div>
      {% endif %}

      {% if figures %}
      <div class="section-block">
        <h2>원문 그림</h2>
        <div class="figures-grid">
          {% for fig in figures %}
          <figure class="figure-card">
            <img src="{{ fig.src }}" alt="{{ fig.caption|default('') |e }}">
            {% if fig.caption %}<figcaption class="figure-caption">{{ fig.caption|e }}</figcaption>{% endif %}
          </figure>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {% if data_charts %}
      <div class="section-block">
        <h2>데이터로 보기</h2>
        <div class="charts-grid" id="charts-grid"></div>
      </div>
      {% endif %}

      {% if methodology %}
      <div class="section-block">
        <h2>방법론</h2>
        <p>{{ methodology|e }}</p>
      </div>
      {% endif %}

      {% if implications %}
      <div class="section-block">
        <h2>시사점</h2>
        <div class="implications-grid">
          {% for label, body in implications.items() %}
          <div class="implication-card">
            <h3>{{ label|e }}</h3>
            <p>{{ body|e }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {% if limitations %}
      <div class="section-block">
        <h2>한계</h2>
        <p>{{ limitations|e }}</p>
      </div>
      {% endif %}

      {% if glossary %}
      <div class="section-block">
        <h2>용어집</h2>
        <ul class="glossary-list">
          {% for g in glossary %}
          <li><dt>{{ g.term|e }}</dt><dd>{{ g.ko|e }}</dd></li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      <div class="section-block">
        <h2>인용 · 링크</h2>
        {% if citation_apa %}<div class="citation-block">{{ citation_apa|e }}</div>{% endif %}
        <div class="links-row">
          {% if links.doi %}<a class="link-pill" href="{{ links.doi }}" target="_blank" rel="noopener noreferrer">DOI →</a>{% endif %}
          {% if links.oa_pdf %}<a class="link-pill" href="{{ links.oa_pdf }}" target="_blank" rel="noopener noreferrer">OA PDF →</a>{% endif %}
          {% if links.journal_homepage %}<a class="link-pill" href="{{ links.journal_homepage }}" target="_blank" rel="noopener noreferrer">JOURNAL HOMEPAGE →</a>{% endif %}
        </div>
        <div style="margin-top: 18px;">
          {% if source_basis == 'fulltext' %}
          <span class="source-basis">FULL TEXT BASIS</span>
          {% else %}
          <span class="source-basis abstract">ABSTRACT BASIS</span>
          {% endif %}
        </div>
      </div>

    </div>
  </section>

  <footer class="article-footer">
    <div class="container">
      <a href="/insight">← BACK TO INSIGHTS</a>
      <span style="margin: 0 16px;">·</span>
      <a href="/">HOME</a>
    </div>
  </footer>
</article>

{% if data_charts %}
<script>
const CHARTS = {{ data_charts_json|safe }};
function renderBarChart(chart) {
  const W = 520, H = 280;
  const PAD_L = 50, PAD_R = 16, PAD_T = 18, PAD_B = 56;
  const plotW = W - PAD_L - PAD_R;
  const plotH = H - PAD_T - PAD_B;
  const max = Math.max(...chart.values);
  const min = Math.min(...chart.values, 0);
  const yMax = max + (max - min) * 0.12;
  const yMin = min < 0 ? min : 0;
  const yRange = yMax - yMin || 1;
  const n = chart.values.length;
  const slot = plotW / n;
  const barW = Math.min(slot * 0.6, 80);
  function yFor(v) { return PAD_T + plotH - ((v - yMin) / yRange) * plotH; }
  const ticks = 4;
  let gridSvg = "";
  for (let i = 0; i <= ticks; i++) {
    const v = yMin + (yRange / ticks) * i;
    const y = yFor(v);
    gridSvg += `<line class="axis-line" x1="${PAD_L}" y1="${y}" x2="${PAD_L + plotW}" y2="${y}"/>`;
    gridSvg += `<text class="axis-label" x="${PAD_L - 8}" y="${y + 4}" text-anchor="end">${Number(v.toFixed(1))}</text>`;
  }
  const maxIdx = chart.values.indexOf(max);
  let barsSvg = "";
  for (let i = 0; i < n; i++) {
    const v = chart.values[i];
    const x = PAD_L + slot * i + (slot - barW) / 2;
    const y = yFor(v);
    const h = (PAD_T + plotH) - y;
    const cls = i === maxIdx ? "bar highlight" : "bar";
    barsSvg += `<rect class="${cls}" x="${x}" y="${y}" width="${barW}" height="${h}" rx="3"/>`;
    barsSvg += `<text class="value-label" x="${x + barW / 2}" y="${y - 6}" text-anchor="middle">${v}${chart.unit || ""}</text>`;
    const label = String(chart.x_labels[i] || "");
    barsSvg += `<text class="axis-label" x="${x + barW / 2}" y="${PAD_T + plotH + 18}" text-anchor="middle">${label}</text>`;
  }
  const yTitle = chart.y_label ? `<text class="y-label" x="${PAD_L}" y="${PAD_T - 6}">${chart.y_label}${chart.unit ? " (" + chart.unit + ")" : ""}</text>` : "";
  return `<svg class="chart-svg" viewBox="0 0 ${W} ${H}" preserveAspectRatio="xMidYMid meet" role="img" aria-label="${chart.title}">${yTitle}${gridSvg}${barsSvg}</svg>`;
}
(function () {
  const grid = document.getElementById("charts-grid");
  if (!grid) return;
  CHARTS.forEach(function (c) {
    const card = document.createElement("div");
    card.className = "chart-card";
    card.innerHTML = `<div class="chart-title">${c.title}</div>` + (c.type === "bar" ? renderBarChart(c) : "");
    grid.appendChild(card);
  });
})();
</script>
{% endif %}

</body>
</html>
