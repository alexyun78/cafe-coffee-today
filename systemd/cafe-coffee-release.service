[Unit]
Description=Cafe Today Coffee — daily insight backlog release (token-free)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/92cafe/cafe-today-coffee
EnvironmentFile=/root/92cafe/cafe-today-coffee/.env
ExecStart=/bin/bash /root/92cafe/cafe-today-coffee/scripts/release.sh
StandardOutput=journal
StandardError=journal
TimeoutStartSec=10min
