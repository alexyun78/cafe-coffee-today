# /etc/nginx/sites-available/cafe-coffee
# 서버에서 실제 도메인/포트에 맞게 조정 후 사용
# 적용: ln -s /etc/nginx/sites-available/cafe-coffee /etc/nginx/sites-enabled/
#      nginx -t && systemctl reload nginx

server {
    listen 80;
    server_name coffee.example.com;   # 실제 도메인으로 교체

    # HTTPS는 certbot으로 추가:
    #   certbot --nginx -d coffee.example.com

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:3002;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
